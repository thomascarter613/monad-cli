{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monad.local/schemas/data/archival-schema.json",
  "title": "Monad Archival Package Manifest",
  "description": "Schema for archive manifests that describe frozen Monad data or evidence packages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "archive_id",
    "archive_type",
    "created_at",
    "created_by",
    "reason",
    "retention_class",
    "source_range",
    "items"
  ],
  "properties": {
    "schema": {
      "const": "monad.data.archive"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "archive_id": {
      "type": "string",
      "minLength": 1
    },
    "archive_type": {
      "type": "string",
      "enum": [
        "release_evidence",
        "migration_snapshot",
        "incident_snapshot",
        "context_snapshot",
        "graph_snapshot",
        "policy_snapshot",
        "repository_snapshot",
        "other"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "ephemeral",
        "operational",
        "release",
        "audit",
        "forensic",
        "permanent"
      ]
    },
    "retain_until": {
      "type": "string",
      "format": "date"
    },
    "source_range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "git_commit": {
          "type": "string"
        },
        "git_ref": {
          "type": "string"
        },
        "from_time": {
          "type": "string",
          "format": "date-time"
        },
        "to_time": {
          "type": "string",
          "format": "date-time"
        },
        "workspace_root": {
          "type": "string"
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "payload",
              "manifest",
              "checksum",
              "signature",
              "report",
              "external_reference"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "content_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validated_at": {
          "type": "string",
          "format": "date-time"
        },
        "validated_by": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_validated",
            "valid",
            "invalid",
            "partial"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
