{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monad.local/schemas/data/forensic-schema.json",
  "title": "Monad Forensic Evidence Record",
  "description": "Schema for forensic records used to preserve evidence about incidents, migrations, failed applies, policy disputes, or suspicious state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "case_id",
    "record_id",
    "recorded_at",
    "recorded_by",
    "event_type",
    "severity",
    "summary",
    "evidence"
  ],
  "properties": {
    "schema": {
      "const": "monad.data.forensic"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_by": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "failed_apply",
        "unsafe_mutation_attempt",
        "policy_bypass_attempt",
        "manifest_conflict",
        "migration_failure",
        "context_leak_risk",
        "cache_corruption",
        "unexpected_network_access",
        "unexpected_ai_access",
        "release_evidence_dispute",
        "other"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "affected_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "related_adrs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "uniqueItems": true
    },
    "related_work_packets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WP-[0-9]{4}$"
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "description"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "file_snapshot",
              "command_output",
              "plan",
              "apply_report",
              "policy_report",
              "graph_export",
              "context_manifest",
              "log_excerpt",
              "checksum",
              "external_reference",
              "human_note"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "captured_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "chain_of_custody": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actor",
          "action",
          "timestamp"
        ],
        "properties": {
          "actor": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "disposition": {
      "type": "string",
      "enum": [
        "open",
        "under_review",
        "mitigated",
        "accepted_risk",
        "false_positive",
        "closed"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
