{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Monad Sprint",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "id",
    "title",
    "status",
    "workpackets"
  ],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "type": {
      "const": "sprint"
    },
    "id": {
      "type": "string",
      "pattern": "^SPRINT-[0-9]{4}$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "planned",
        "ready",
        "active",
        "blocked",
        "review",
        "done",
        "deferred",
        "superseded"
      ]
    },
    "milestone": {
      "type": "string"
    },
    "workpackets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WP-[0-9]{4}$"
      }
    }
  },
  "additionalProperties": true
}
