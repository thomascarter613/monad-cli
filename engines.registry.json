{
  "schemaVersion": 1,
  "kind": "DeterministicEngineRegistry",
  "policy": {
    "noImplicitEngines": true,
    "pinVersions": true,
    "preferLocalTooling": true,
    "hiddenEngineChangesRequireWorkPacket": true
  },
  "engines": [
    {
      "name": "rust",
      "category": "language",
      "versionSource": "rust-toolchain.toml",
      "required": true
    },
    {
      "name": "cargo",
      "category": "build",
      "versionSource": "rust-toolchain.toml",
      "required": true
    },
    {
      "name": "bun",
      "category": "package-manager",
      "version": "1.1.x",
      "required": true
    },
    {
      "name": "turbo",
      "category": "task-orchestrator",
      "package": "turbo",
      "version": "^2.0.0",
      "required": false
    },
    {
      "name": "moon",
      "category": "task-orchestrator",
      "package": "@moonrepo/cli",
      "version": "^1.30.0",
      "required": false
    },
    {
      "name": "biome",
      "category": "code-quality",
      "package": "@biomejs/biome",
      "version": "^1.9.0",
      "required": false
    },
    {
      "name": "knip",
      "category": "dependency-pruning",
      "package": "knip",
      "version": "^5.0.0",
      "required": false
    },
    {
      "name": "syncpack",
      "category": "dependency-consistency",
      "package": "syncpack",
      "version": "^13.0.0",
      "required": false
    },
    {
      "name": "vitest",
      "category": "testing",
      "package": "vitest",
      "version": "^2.0.0",
      "required": false
    },
    {
      "name": "playwright",
      "category": "e2e-testing",
      "package": "@playwright/test",
      "version": "^1.45.0",
      "required": false
    },
    {
      "name": "changesets",
      "category": "versioning",
      "package": "@changesets/cli",
      "version": "^2.27.0",
      "required": false
    },
    {
      "name": "semgrep",
      "category": "static-analysis",
      "version": "managed-by-ci-or-local-install",
      "required": false
    },
    {
      "name": "syft",
      "category": "sbom",
      "version": "managed-by-ci-or-local-install",
      "required": false
    },
    {
      "name": "cyclonedx",
      "category": "sbom",
      "version": "managed-by-ci-or-local-install",
      "required": false
    }
  ]
}
