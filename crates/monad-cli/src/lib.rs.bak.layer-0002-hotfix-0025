use clap::{Arg, ArgAction, ArgMatches, Command};
use serde::Serialize;

pub fn main_entry() -> std::process::ExitCode {
    // __MONAD_NO_ARGS_HELP_GUARD__
    if std::env::args_os().len() == 1 {
        let mut command = build_cli();
        if let Err(error) = command.print_help() {
            eprintln!("error: {error}");
            return std::process::ExitCode::from(1);
        }
        println!("\n\nDefault scope: @monad");
        return std::process::ExitCode::SUCCESS;
    }

    match run() {
        Ok(()) => std::process::ExitCode::SUCCESS,
        Err(error) => {
            eprintln!("error: {error}");
            std::process::ExitCode::from(1)
        }
    }
}

fn run() -> Result<(), String> {
    let matches = build_cli().get_matches();
    let json = matches.get_flag("json");

    match matches.subcommand() {
        Some(("version", sub)) => emit_version(sub, json),
        Some(("check", sub)) => emit_check(sub, json),
        Some(("doctor", sub)) => emit_doctor(sub, json),
        Some(("inspect", sub)) => emit_inspect(sub, json),
        Some(("list", sub)) => emit_list(sub, json),
        Some(("config", sub)) => emit_config(sub, json),
        Some(("diff", sub)) => emit_diff(sub, json),
        Some(("context", sub)) => emit_context(sub, json),
        Some(("plan", sub)) => emit_plan(sub, json),
        Some(("apply", sub)) => emit_apply(sub, json),
        Some(("pack", sub)) if matches_subcommand(sub, "list") => emit_pack_list(json),
        Some((command, sub)) => {
            let path = command_path(command, sub);
            emit_placeholder(json, &path)
        }
        None => Ok(()),
    }
}

pub fn build_cli() -> Command {
    cli()
