fn include_section(output: &InspectCommandOutput, section: &str) -> bool {
    let Some(include) = output.include.as_deref() else {
        return true;
    };

    include
        .split(',')
        .map(str::trim)
        .any(|item| item.eq_ignore_ascii_case(section))
}

